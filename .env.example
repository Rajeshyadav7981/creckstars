# ══════════════════════════════════════════════════════════
# CrecKStars Backend — Environment Configuration
# Copy this to .env and update values for your environment
# ══════════════════════════════════════════════════════════

# ── Environment ──
ENVIRONMENT=development

# ── Database ──
DB_HOST=localhost
DB_PORT=5432
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_NAME=creckstars

# ── Redis ──
REDIS_URL=redis://localhost:6379/0

# ── JWT / Auth ──
SECRET_KEY=CHANGE_ME_TO_A_STRONG_RANDOM_STRING_32_CHARS_MIN
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_MINUTES=10080

# ── OTP ──
OTP_EXPIRE_MINUTES=5

# ── CORS ──
CORS_ORIGINS=*

# ── Deep Linking / Share ──
APP_SCHEME=creckstars
APP_PACKAGE_NAME=com.creckstars.app
APP_DOWNLOAD_URL=
SHARE_BASE_URL=
APP_SHA256_FINGERPRINT=

# ── App Version (fallback — prefer releases/version.json) ──
APP_LATEST_VERSION=1.0.0
APP_LATEST_VERSION_CODE=1
APP_MIN_VERSION=1.0.0
APP_RELEASE_NOTES=Bug fixes and performance improvements

# ── Rate Limiting ──
RATE_LIMIT_DEFAULT=200/minute
RATE_LIMIT_REGISTER=5/minute
RATE_LIMIT_LOGIN=10/minute
RATE_LIMIT_SCORE=120/minute
RATE_LIMIT_UNDO=30/minute
RATE_LIMIT_BROADCAST=20/minute
RATE_LIMIT_CREATE_POST=30/minute
RATE_LIMIT_LIST_POSTS=60/minute
RATE_LIMIT_LIKE=60/minute
RATE_LIMIT_COMMENT=30/minute
RATE_LIMIT_LIST_MATCHES=60/minute
RATE_LIMIT_LIST_TOURNAMENTS=60/minute
RATE_LIMIT_CREATE_TOURNAMENT=10/minute
RATE_LIMIT_CREATE_TEAM=20/minute
RATE_LIMIT_CREATE_MATCH=20/minute
RATE_LIMIT_CREATE_PLAYER=30/minute
