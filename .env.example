# CrecKStars backend — environment template. Copy to .env and fill real values.
# IMPORTANT: no leading whitespace on any line (pydantic-settings + the env
# loader both break silently if a line starts with a space/tab).

ENVIRONMENT=production
SECRET_KEY=change-me-to-a-long-random-string

DB_HOST=localhost
DB_PORT=5432
DB_USER=creckstars
DB_PASSWORD=change-me
DB_NAME=creckstars

REDIS_URL=redis://localhost:6379/0

# Message Central VerifyNow (SMS OTP)
VERIFYNOW_CUSTOMER_ID=
VERIFYNOW_AUTH_TOKEN=

# Offsite backups (used by scripts/backup.sh)
GCS_BUCKET=gs://creckstars-backups
RETENTION_DAYS=14
